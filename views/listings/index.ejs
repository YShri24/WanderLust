<% layout("/layouts/boilerplate") %>
 
  <!-- <h3>All Listings</h3> -->

  <div class="row row-cols-lg-3 row-cols-md-3 row-cols-sm-1">
    <% for(let listing of allListings) { %>
      
      <div class="col">
        <a href="/listings/<%=listing._id%>" class="listing-link">
              <div class="card mb-4 listing-card">
        
        <div class="image-container">
          <img src="<%= listing.image?.url %>" 
              class="card-img-top listing-image" 
              alt="listing_image">

          <!-- Overlay -->
          <div class="overlay">
            <span>View Details</span>
          </div>
        </div>

        <div class="card-body">
          <p class="card-text">
            <b><%= listing.title %></b><br><br>
            &#8377; <%= (listing.price || 0).toLocaleString("en-IN") %> /night
          </p>
        </div>

      </div>
        </a>
      </div>

    <% } %>
  </div>
